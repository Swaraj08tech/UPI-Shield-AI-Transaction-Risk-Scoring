# ---------------------------------------------------------
# Python cache files
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ---------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------
venv/
.env
.venv/
env/
ENV/

# ---------------------------------------------------------
# Jupyter Notebook checkpoints
# ---------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------
# Large dataset files
# ---------------------------------------------------------
data/raw/*.csv
data/raw/*.zip
data/raw/*.xlsx
data/raw/*.parquet

data/processed/*.csv
data/processed/*.parquet
data/processed/*.pkl
data/processed/*.joblib

# ---------------------------------------------------------
# Trained model files
# ---------------------------------------------------------
models/*.pkl
models/*.joblib
models/*.h5
models/*.keras

# ---------------------------------------------------------
# Kaggle API token
# ---------------------------------------------------------
kaggle.json

# ---------------------------------------------------------
# Reports that may become large
# ---------------------------------------------------------
reports/*prediction_results*.csv
reports/*sample*.csv

# ---------------------------------------------------------
# OS files
# ---------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------
# VS Code files
# ---------------------------------------------------------
.vscode/

# ---------------------------------------------------------
# Streamlit secrets
# Keep config.toml allowed, ignore only secrets
# ---------------------------------------------------------
.streamlit/secrets.toml

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log